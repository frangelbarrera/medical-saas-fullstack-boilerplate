# PostgreSQL Configuration
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=medical_saas_db

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Auth Secrets - REQUIRED, no defaults. Generate with:
#   openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_random_value_min_32_chars
ENCRYPTION_KEY=replace_with_64_char_hex_random_value_exactly_64_chars

# Payment Gateway (Payphone / Stripe / etc.)
PAYMENT_GATEWAY_TOKEN=
PAYMENT_GATEWAY_URL=https://pay.payphone.com.ec/api/button/Prepare
# Webhook HMAC secret - shared with payment gateway for signature verification
PAYMENT_WEBHOOK_SECRET=replace_with_min_16_char_random_secret

# AI Integration
GEMINI_API_KEY=
# PHI handling before LLM calls: strip | redact | passthrough
# strip: removes PHI fields entirely (default, safe without BAA)
# redact: masks PHI with placeholders
# passthrough: sends PHI as-is (REQUIRES signed BAA with Google)
LLM_PHI_MODE=strip
