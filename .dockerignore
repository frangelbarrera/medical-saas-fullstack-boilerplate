# Version control
.git
.gitignore
.github

# Dependencies (regenerated inside container)
node_modules

# Build output (regenerated inside container)
dist
build

# Environment files (must be provided via docker-compose env)
.env
.env.*
!.env.example

# Heavy assets (57MB+) - serve from CDN in production, not from the image
public/background.mp4
public/fondo*.jpg
public/Screenshots

# Documentation and metadata
README.md
CONTRIBUTING.md
DEPLOYMENT_GUIDE.md
SECURITY.md
LICENSE
*.md
!src/**/*.md

# IDE and OS files
.vscode
.idea
.DS_Store
*.swp
*.swo

# Logs and temp files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp
temp

# Test files (not needed in production image)
tests
__tests__
*.test.ts
*.spec.ts
coverage
vitest.config.ts

# Database files
*.sqlite
*.db
